{
  "kind": "collectionType",
  "collectionName": "payments",
  "info": {
    "singularName": "payment",
    "pluralName": "payments",
    "displayName": "Payment"
  },
  "options": { "draftAndPublish": false },
  "pluginOptions": {},
  "attributes": {
    "telegramChargeId": { "type": "string", "unique": true },
    "provider": {
      "type": "enumeration",
      "enum": ["telegram", "ton"],
      "required": true,
      "default": "telegram"
    },
    "tonTxHash": { "type": "string", "unique": true },
    "intentId": { "type": "string", "unique": true },
    "usdtAmount": { "type": "float" },
    "payloadType": {
      "type": "enumeration",
      "enum": ["subscription", "vacancy_pack", "apply_pack", "urgent", "top_placement"],
      "required": true
    },
    "planCode": { "type": "string" },
    "packageId": { "type": "integer" },
    "vacancyDocumentId": { "type": "string" },
    "user": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::users-permissions.user"
    },
    "starsAmount": { "type": "integer" },
    "status": {
      "type": "enumeration",
      "enum": ["processing", "completed", "failed"],
      "default": "processing",
      "required": true
    }
  }
}
