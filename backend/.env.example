
# ============================================
# SERVER
# ============================================
HOST=0.0.0.0
PORT=1337
NODE_ENV=development

# ============================================
# STRAPI SECRETS
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# ============================================
APP_KEYS=changeme1,changeme2,changeme3,changeme4
API_TOKEN_SALT=changeme
ADMIN_JWT_SECRET=changeme
TRANSFER_TOKEN_SALT=changeme
ENCRYPTION_KEY=changeme
JWT_SECRET=changeme

# ============================================
# DATABASE
# ============================================
DATABASE_CLIENT=postgres
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=gramjob
DATABASE_USERNAME=gramjob
DATABASE_PASSWORD=secret
DATABASE_SSL=false

# ============================================
# S3 STORAGE (MinIO local / Cloudflare R2 prod)
# ============================================
S3_ACCESS_KEY_ID=gramjob
S3_SECRET_ACCESS_KEY=changeme  # MinIO local default: secret123
S3_REGION=us-east-1
S3_BUCKET=gramjob
S3_ENDPOINT=http://localhost:9000
S3_FORCE_PATH_STYLE=true
# Public URL prefix for media files (e.g. https://media.gramjob.com or R2 public bucket URL).
# Must match S3_PUBLIC_HOSTNAME below. Leave empty for local dev (MinIO served via Strapi proxy).
S3_PUBLIC_URL=
# Hostname of the public media domain — added to CSP img-src / media-src.
# Example: media.gramjob.com  (without protocol)
S3_PUBLIC_HOSTNAME=
# Дополнительный хост, чей URL считается «своим» для аватаров/uploads.
# Используется, когда провайдер аплоада возвращает абсолютный URL с API-домена
# (например https://api.gramjob.com/uploads/...), а S3_PUBLIC_URL указывает
# на другой хост (или пуст). Относительные пути /uploads/* работают всегда.
PUBLIC_UPLOADS_URL=

# ============================================
# TELEGRAM
# ============================================
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=gramjob_bot
TELEGRAM_WEBHOOK_URL=https://api.gramjob.com/api/telegram/webhook
TELEGRAM_WEBHOOK_SECRET=changeme
# Chat ID администраторов для уведомлений о модерации (через запятую)
ADMIN_TELEGRAM_CHAT_IDS=
# Базовый URL админки для ссылок в уведомлениях (например https://api.gramjob.com/admin)
ADMIN_URL=

# ============================================
# APP
# ============================================
FRONTEND_URL=http://localhost:3000

# ============================================
# EMAIL (SMTP)
# Local dev: Mailpit из docker-compose (web UI: http://localhost:8025)
# ============================================
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@gramjob.com

# ============================================
# TON / USDT PAYMENTS
# Альтернативный платёжный метод: USDT-on-TON через TON Connect
# ============================================
# Сеть: mainnet или testnet (default: testnet)
TON_NETWORK=testnet
# TON-адрес кошелька мерчанта для приёма USDT (обязателен)
TON_MERCHANT_ADDRESS=
# HMAC-SHA256 секрет для проверки подписи TON Pay вебхука
# Генерация: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TON_PAY_WEBHOOK_SECRET=changeme
# Адрес USDT Jetton Master в testnet (для mainnet вшит в код)
# Пример testnet USDT: EQD__...
TON_USDT_MASTER_TESTNET=
# API-ключ Tonapi.io для polling статуса транзакции (опционально — без ключа работает медленнее)
# Получить: https://tonconsole.com
TONAPI_KEY=

# ============================================
# SENTRY (опционально — без DSN не активируется)
# ============================================
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_RELEASE=
SENTRY_TRACES_SAMPLE_RATE=0
