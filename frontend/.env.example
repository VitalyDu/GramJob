# ============================================
# API
# ============================================
NEXT_PUBLIC_API_URL=http://localhost:1337/api
NEXT_PUBLIC_STRAPI_URL=http://localhost:1337
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ============================================
# TELEGRAM
# ============================================
NEXT_PUBLIC_BOT_USERNAME=gramjob_bot
NEXT_PUBLIC_MINI_APP_URL=https://t.me/gramjob_bot/app

# ============================================
# AUTH
# ============================================
NEXTAUTH_SECRET=changeme
NEXTAUTH_URL=http://localhost:3000

# ============================================
# TON CONNECT (USDT платежи)
# ============================================
# URL манифеста TON Connect (по умолчанию /tonconnect-manifest.json)
NEXT_PUBLIC_TONCONNECT_MANIFEST_URL=https://gramjob.com/tonconnect-manifest.json
# API Tonapi.io для определения Jetton wallet адреса пользователя
# Получить: https://tonconsole.com (опционально — без ключа rate limit ниже)
NEXT_PUBLIC_TONAPI_KEY=

# ============================================
# SENTRY (опционально — без DSN не активируется)
# ============================================
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_ENVIRONMENT=production
NEXT_PUBLIC_SENTRY_RELEASE=
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0
# Серверный DSN (обычно совпадает с NEXT_PUBLIC_SENTRY_DSN)
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_RELEASE=
SENTRY_TRACES_SAMPLE_RATE=0
# Для загрузки sourcemaps через withSentryConfig (опционально)
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
